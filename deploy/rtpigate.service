[Unit]
Description=rtpigate - APRS iGate consuming the aprs-streamd decoded-APRS stream
Documentation=https://github.com/Deatojef/rtpigate
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rtpigate
Group=rtpigate
ExecStart=/usr/local/bin/rtpigate /etc/rtpigate/config.toml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rtpigate

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/tmp
PrivateTmp=true

# Persistent statistics store (native_db). StateDirectory creates and owns
# /var/lib/rtpigate (mode 0700, User/Group above) and grants read-write access
# under ProtectSystem=strict. The config's [storage] path points here.
StateDirectory=rtpigate

[Install]
WantedBy=multi-user.target
